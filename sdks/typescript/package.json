{
  "name": "@vantax/atheon-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for Atheon — Enterprise Intelligence Platform.",
  "license": "Apache-2.0",
  "homepage": "https://atheon.vantax.co.za",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VantaX-Org/Atheon.git",
    "directory": "sdks/typescript"
  },
  "keywords": ["atheon", "sdk", "vantax", "erp", "ai", "catalyst"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
