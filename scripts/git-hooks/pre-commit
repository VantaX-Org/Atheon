#!/usr/bin/env bash
# Atheon pre-commit hook.
#
# Runs gitleaks against staged changes to catch secrets before they leave the
# developer's machine. Fails closed: if gitleaks is installed and finds a leak,
# the commit is rejected. If gitleaks is NOT installed, prints a one-time
# warning and lets the commit through — we don't want to block work on a
# brand-new clone before the dev has had a chance to install the tool, but the
# warning makes it obvious that the safety net is missing.
#
# Install:  npm run setup:hooks
# Bypass:   git commit --no-verify   (only with explicit reviewer sign-off)

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

if command -v gitleaks >/dev/null 2>&1; then
  cd "$repo_root"
  if ! gitleaks protect --staged --no-banner --redact -v; then
    echo
    echo "❌ gitleaks found a potential secret in your staged changes."
    echo "   Remove the secret (or rotate it if already leaked) and try again."
    echo "   If this is a false positive, add an allowlist entry to .gitleaks.toml."
    exit 1
  fi
  exit 0
fi

cat <<'WARN' >&2
⚠️  gitleaks not installed — committing without secret scan.
   Install:  brew install gitleaks   (or see https://github.com/gitleaks/gitleaks)
   Then re-run: npm run setup:hooks
WARN
exit 0
