# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
workers/api/tsconfig.tsbuildinfo

# Claude Agent worktree sidecars — local-only, never commit
.claude/worktrees/
.claude/projects/

# MCP server config carries credentials — keep local
.mcp.json

# Local test DB artefacts
workers/api/schema.db
workers/api/.wrangler/
.wrangler/

# Playwright outputs — local-only, never commit
test-results/
playwright-report/
.playwright/
.playwright-mcp/
.superpowers/

# Vitest coverage output — regenerated each run
coverage/

# Verification harness local state — globalSetup rebuilds this each run
verification/.run-manifest.json

# Local session handoff — written by SessionStart hook, never commit
.remember/

# Local screenshots / UI walks — keep on disk, never commit
/*.png
/*.jpeg
/*.jpg
/*.webp

# Stray root-level wrangler config that shadows workers/api/wrangler.toml
# (see docs/runbooks/go-live.md "stray wrangler.jsonc shadows ..." entry)
/wrangler.jsonc
graphify-out/
