{
  "name": "atheon-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "size:check": "node scripts/check-bundle-size.mjs",
    "verify:accuracy": "vitest run --config vitest.verification.config.ts verification/accuracy",
    "verify:isolation": "vitest run --config vitest.verification.config.ts verification/isolation",
    "verify:rbac": "vitest run --config vitest.verification.config.ts verification/rbac",
    "verify:matrices": "vitest run --config vitest.verification.config.ts",
    "verify:load": "tsx verification/load/load-gate.ts",
    "verify:dr": "tsx verification/dr/restore-drill.ts",
    "setup:hooks": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@types/papaparse": "^5.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.364.0",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.12.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.68.1"
  }
