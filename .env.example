# ═══════════════════════════════════════════════════════════════════════════
# Atheon™ Hybrid / On-Premise Deployment — Environment Variables
# Copy this file to .env and fill in the values provided by GONXT.
# ═══════════════════════════════════════════════════════════════════════════

# ── Agent Configuration (provided by GONXT during provisioning) ──────────
ATHEON_DEPLOYMENT_ID=
ATHEON_LICENCE_KEY=
# On-premise default: agent talks to local API container. Override only for hybrid cloud mode.
ATHEON_CONTROL_PLANE_URL=http://api:3000
ATHEON_HEARTBEAT_INTERVAL=60

# ── API Configuration ────────────────────────────────────────────────────
JWT_SECRET=CHANGEME_32_CHARS_MIN
ENCRYPTION_KEY=CHANGEME_32_CHARS_MIN
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://atheon:atheon@db:5432/atheon
POSTGRES_USER=atheon
POSTGRES_PASSWORD=atheon
POSTGRES_DB=atheon

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Object Storage (MinIO) ───────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=atheon-storage
MINIO_ACCESS_KEY=atheon
MINIO_SECRET_KEY=CHANGEME

# ── LLM (Ollama) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434

# ── API Image Tag ────────────────────────────────────────────────────────
ATHEON_API_TAG=latest
